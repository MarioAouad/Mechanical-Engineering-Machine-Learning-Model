# ===========================================================================
# .gitignore — Acoustic Anomaly Detection (DCASE 2024 Task 2)
# ===========================================================================
# This file tells Git which files/folders to NEVER track or upload.
# Large binary data, model weights, and environment files do not
# belong in version control — they bloat the repo and leak secrets.
# ===========================================================================

# -----------------------------------------------------------------------
# 1. RAW AUDIO DATA
#    The DCASE dataset contains thousands of .wav files (hundreds of MB).
#    These must be downloaded separately by each collaborator.
# -----------------------------------------------------------------------
data/raw/

# -----------------------------------------------------------------------
# 2. PROCESSED DATA (NumPy arrays + scalers)
#    Spectrograms generated by src/preprocessing/preprocess_v1.py and
#    preprocess_v2.py. Can be regenerated from raw audio.
# -----------------------------------------------------------------------
data/processed_v1/
data/processed_v2/
*.npy
*.npz

# -----------------------------------------------------------------------
# 3. MODEL WEIGHTS (PyTorch checkpoints)
#    Trained autoencoder weights — too large for Git (~2-3 MB each).
# -----------------------------------------------------------------------
weights/
*.pth
*.pt

# -----------------------------------------------------------------------
# 4. SERIALIZED ML OBJECTS (Scikit-learn / Joblib)
#    Fitted scalers, KNN models, GMMs. Must be regenerated locally.
# -----------------------------------------------------------------------
*.save
*.pkl
*.joblib

# -----------------------------------------------------------------------
# 5. MONITORING LOGS
#    Prediction logs from the API server (can grow very large).
# -----------------------------------------------------------------------
logs/

# -----------------------------------------------------------------------
# 6. GENERATED OUTPUTS
#    Training curves, ROC plots, score distributions — regeneratable.
# -----------------------------------------------------------------------
outputs/

# -----------------------------------------------------------------------
# 7. DOWNLOADED ARCHIVES
# -----------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.7z

# -----------------------------------------------------------------------
# 8. PYTHON CACHE & BYTECODE
# -----------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/

# -----------------------------------------------------------------------
# 9. JUPYTER NOTEBOOK CHECKPOINTS
# -----------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------
# 10. VIRTUAL ENVIRONMENTS
# -----------------------------------------------------------------------
venv/
env/
.env/
.venv/
ENV/

# -----------------------------------------------------------------------
# 11. IDE & EDITOR FILES
# -----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------
# 12. OS-GENERATED FILES
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------
# 13. DISTRIBUTION / PACKAGING
# -----------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg

# -----------------------------------------------------------------------
# 14. MLflow (if used for experiments)
# -----------------------------------------------------------------------
mlruns/
mlflow.db
mlflow_pipeline/

# -----------------------------------------------------------------------
# EXCEPTIONS — Files we WANT to keep despite the rules above
# .gitkeep files preserve empty directory structure on GitHub.
# -----------------------------------------------------------------------
!.gitkeep
