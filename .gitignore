# ===========================================================================
# .gitignore — Acoustic Anomaly Detection (DCASE 2024 Task 2)
# ===========================================================================
# This file tells Git which files/folders to NEVER track or upload.
# Large binary data, model weights, and environment files do not
# belong in version control — they bloat the repo and leak secrets.
# ===========================================================================

# -----------------------------------------------------------------------
# 1. RAW AUDIO DATA
#    The DCASE dataset contains thousands of .wav files (hundreds of MB).
#    These must be downloaded separately by each collaborator.
# -----------------------------------------------------------------------
*.wav
*.flac
*.mp3
*.ogg
*.aiff
*.aif
data/raw/**/*.wav
data/raw/**/*.flac

# -----------------------------------------------------------------------
# 2. PROCESSED DATA (NumPy arrays)
#    Log-Mel Spectrogram matrices generated by 01_data_prep.ipynb.
#    These are large binary files that can be regenerated from raw audio.
# -----------------------------------------------------------------------
*.npy
*.npz
data/processed/**/*.npy
data/processed/**/*.npz

# -----------------------------------------------------------------------
# 3. SAVED MODEL WEIGHTS (PyTorch)
#    Trained Autoencoder checkpoints — too large for Git.
# -----------------------------------------------------------------------
*.pth
*.pt

# -----------------------------------------------------------------------
# 4. SAVED SCALER OBJECTS (Scikit-learn / Joblib)
#    MinMaxScaler fitted on training data. Must be regenerated locally.
# -----------------------------------------------------------------------
*.save
*.pkl
*.joblib

# -----------------------------------------------------------------------
# 5. DOWNLOADED DATASET ARCHIVES
#    ZIP/TAR files from the DCASE 2024 website.
# -----------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.7z

# -----------------------------------------------------------------------
# 6. PYTHON CACHE & BYTECODE
# -----------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/

# -----------------------------------------------------------------------
# 7. JUPYTER NOTEBOOK CHECKPOINTS
#    Auto-saved copies that clutter version history.
# -----------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------
# 8. VIRTUAL ENVIRONMENTS
#    Each developer creates their own locally.
# -----------------------------------------------------------------------
venv/
env/
.env/
.venv/
ENV/

# -----------------------------------------------------------------------
# 9. IDE & EDITOR FILES
# -----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------
# 10. OS-GENERATED FILES
# -----------------------------------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------
# 11. DISTRIBUTION / PACKAGING
# -----------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg

# -----------------------------------------------------------------------
# EXCEPTIONS — Files we WANT to keep despite the rules above
# .gitkeep files preserve empty directory structure on GitHub.
# -----------------------------------------------------------------------
!.gitkeep
